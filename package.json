{
  "name": "k-suite",
  "version": "2.1.2",
  "main": "src/main/main.js",
  "author": "Loatrix <loan@schoning.ch>",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.infomaniak.ksuite",
    "productName": "K-Suite",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/icons/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "K-Suite"
    }
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-dl": "^4.0.0",
    "electron-store": "^11.0.2",
    "keytar": "^7.9.0",
    "node-fetch": "^3.3.2"
  },
  "description": "**K-Suite Workstation** est une application de productivité basée sur Electron, conçue pour centraliser et optimiser l'utilisation de l'écosystème Infomaniak (Manager, Mail, kDrive, SwissTransfer).",
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LoatrX/K-Suite-App-Win.git"
  },
  "keywords": [],
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/LoatrX/K-Suite-App-Win/issues"
  },
  "homepage": "https://github.com/LoatrX/K-Suite-App-Win#readme"
}
