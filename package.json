{
  "name": "k-suite",
  "version": "2.1.1",
  "main": "src/main/main.js",
  "author": "Loatrix <loan@schoning.ch>",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.infomaniak.ksuite",
    "productName": "K-Suite",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/icons/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "K-Suite"
    }
  }
}